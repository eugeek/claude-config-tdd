{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "@executeautomation/mcp-chrome-devtools"],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/mcp-context7"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  }
}
