{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git remote -v)",
      "Read(**/*)",
      "Read(.env.example)",
      "Write(.env.example)",
      "Edit(.env.example)"
    ],
    "deny": [
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)",
      "Bash(git reset *)",
      "Bash(git clone *)",
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Read(**/.env)",
      "Read(.env)",
      "Write(**/.env)",
      "Write(.env)",
      "Edit(**/.env)",
      "Edit(.env)"
    ]
  },
  
  "env": {
    "EDITOR": "vim"
  }
}
