{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(npx *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git remote -v)",
      "Bash(vitest *)",
      "Bash(jest *)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(python -m mypy *)",
      "Bash(tsc *)",
      "Bash(mypy *)",
      "Bash(ruff *)",
      "Bash(eslint *)",
      "Bash(biome *)",
      "Bash(flake8 *)",
      "Read(**/*)",
      "Read(.env.example)",
      "Write(.env.example)",
      "Edit(.env.example)"
    ],
    "deny": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git stash *)",
      "Bash(git clone *)",
      "Bash(rtk git add *)",
      "Bash(rtk git commit *)",
      "Bash(rtk git push *)",
      "Bash(rtk git pull *)",
      "Bash(rtk git merge *)",
      "Bash(rtk git rebase *)",
      "Bash(rtk git reset *)",
      "Bash(rtk git stash *)",
      "Bash(rtk git clone *)",
      "Bash(sudo *)",
      "Bash(rm *)",
      "Read(**/.env)",
      "Read(.env)",
      "Write(**/.env)",
      "Write(.env)",
      "Edit(**/.env)",
      "Edit(.env)"
    ]
  },

  "env": {
    "EDITOR": "vim"
  }
}
